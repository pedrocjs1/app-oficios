{
  "expo": {
    "name": "OficioYa",
    "slug": "oficioya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oficioya",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oficioya.app"
    },
    "android": {
      "package": "com.oficioya.app",
      "adaptiveIcon": {
        "backgroundColor": "#FF6B1A",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "OficioYa necesita tu ubicación para mostrarte profesionales cercanos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B1A"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "OficioYa necesita acceso a tus fotos para adjuntar imágenes al pedido.",
          "cameraPermission": "OficioYa necesita la cámara para tomar fotos del problema."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
